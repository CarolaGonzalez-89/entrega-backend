<link rel="stylesheet" href="/css/main.css" />
<link rel="stylesheet" href="/css/realtimeproducts.css" />

<div class="admin-container">

  <h1 class="admin-title">Gestionar Productos</h1>

  <div class="forms-container">

   

    <section class="form-section">

      <h2 class="form-title">Añadir producto</h2>

      <form id="addProductForm" class="product-form">

        <div class="form-group">
          <input
            class="form-input"
            type="text"
            name="title"
            placeholder="Título"
            required
          />
        </div>

        <div class="form-group">
          <input
            class="form-input"
            type="text"
            name="description"
            placeholder="Descripción"
            required
          />
        </div>

        <div class="form-group">
          <input
            class="form-input"
            type="number"
            name="price"
            placeholder="Precio"
            required
          />
        </div>

        <div class="form-group">
          <input
            class="form-input"
            type="text"
            name="code"
            placeholder="Código"
            required
          />
        </div>

        <div class="form-group">
          <input
            class="form-input"
            type="number"
            name="stock"
            placeholder="Stock"
            required
          />
        </div>

        <div class="form-group">
          <input
            class="form-input"
            type="text"
            name="category"
            placeholder="Categoría"
            required
          />
        </div>

        <div class="form-group">
          <select class="form-select" name="status">
            <option value="true">Disponible</option>
            <option value="false">No disponible</option>
          </select>
        </div>

        <div class="form-group">
          <input
            class="form-input"
            type="text"
            name="thumbnails"
            placeholder="URL de imagen (opcional)"
          />
        </div>

        <button type="submit" class="btn btn-add">
          Agregar producto
        </button>

      </form>

    </section>

   

    <section class="form-section">

      <h2 class="form-title">Eliminar producto</h2>

      <form id="deleteProductForm" class="product-form">

        <div class="form-group">
          <input
            class="form-input"
            type="text"
            name="pid"
            placeholder="ID del producto"
            required
          />
        </div>

        <button type="submit" class="btn btn-delete">
          Eliminar producto
        </button>

      </form>

    </section>

  </div>

</div>


<h2 class="admin-title">Catalogo de productos</h2>

<div class="products-admin-container" id="productsContainer">

</div>

<script src="/socket.io/socket.io.js"></script>
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
<script src="/js/client.js"></script>